#: prefs.js:59
msgid "Show Extracted Text Notification"
msgstr "Mostra notifica di testo estratto"

#: prefs.js:60
msgid "Displays a system banner containing your copied text context."
msgstr ""
"Visualizza un banner di sistema contenente il contesto del testo copiato."

#: prefs.js:74
msgid "Enable Extraction History"
msgstr "Abilita cronologia di estrazione"

#: prefs.js:75
msgid "Keep a history of up to 15 recent extractions in the context menu."
