#: prefs.js:315
msgid "Target Language Code"
msgstr "ٹارگٹ لینگویج کوڈ"

#: prefs.js:316
msgid "e.g., en, fr, es, zh. Leave empty to use your system default language."
msgstr ""
"جیسے، en، fr، es، zh۔ اپنے سسٹم کی ڈیفالٹ زبان استعمال کرنے کے لیے خالی چھوڑ "
"دیں۔"

#: prefs.js:333
msgid "Logging"
msgstr "لاگنگ"

#: prefs.js:337
msgid "Enable Debug Logging"
msgstr "ڈیبگ لاگنگ کو فعال کریں۔"

#: prefs.js:338
msgid "Outputs detailed OCR and process logs to the system journal."
msgstr "سسٹم جرنل میں تفصیلی OCR اور پروسیس لاگ آؤٹ پٹ کرتا ہے۔"

