#: prefs.js:90
msgid "Allow triggering extraction via a keyboard shortcut."
msgstr "விசைப்பலகை குறுக்குவழி வழியாக பிரித்தெடுத்தலைத் தூண்டுவதை அனுமதிக்கவும்."

#: prefs.js:104
