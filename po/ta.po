#: prefs.js:44
msgid ""
"Instantly extract and copy text to your clipboard from anywhere on the "
"screen."
msgstr ""
"திரையில் எங்கிருந்தும் உங்கள் கிளிப்போர்டுக்கு உரையை உடனடியாக பிரித்தெடுத்து "
"நகலெடுக்கவும்."

#: prefs.js:55
msgid "Behavior & Shortcuts"
msgstr "நடத்தை & குறுக்குவழிகள்"

#: prefs.js:59
msgid "Show Extracted Text Notification"
msgstr "பிரித்தெடுக்கப்பட்ட உரை அறிவிப்பைக் காட்டு"

#: prefs.js:60
msgid "Displays a system banner containing your copied text context."
msgstr "நீங்கள் நகலெடுத்த உரை சூழலைக் கொண்ட கணினி பேனரைக் காட்டுகிறது."

#: prefs.js:74
msgid "Enable Extraction History"
msgstr "பிரித்தெடுத்தல் வரலாற்றை இயக்கு"

#: prefs.js:75
msgid "Keep a history of up to 15 recent extractions in the context menu."
msgstr "சூழல் மெனுவில் 15 சமீபத்திய பிரித்தெடுத்தல்களின் வரலாற்றை வைத்திருங்கள்."

#: prefs.js:89
