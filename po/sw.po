msgstr "Msimbo wa Lugha Lengwa"

#: prefs.js:334
msgid "e.g., en, fr, es, zh. Leave empty to use your system default language."
msgstr ""
"k.m., en, fr, es, zh. Acha tupu ili kutumia lugha chaguomsingi ya mfumo wako."

