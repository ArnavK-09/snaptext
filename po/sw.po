"QR."

#: prefs.js:246
msgid "Translation (Experimental)"
msgstr "Tafsiri (ya Majaribio)"

#: prefs.js:277
msgid "Privacy warning"
msgstr "Onyo la faragha"

#: prefs.js:284
msgid ""
"Auto-Translate sends extracted text to Google Translate. Privacy cannot be "
"guaranteed when enabled."
msgstr ""
"Tafsiri Kiotomatiki hutuma maandishi yaliyotolewa kwa Google Tafsiri. "
"Faragha haiwezi kuhakikishwa ikiwa imewashwa."

#: prefs.js:300
msgid "Auto-Translate Text"
msgstr "Tafsiri Kiotomatiki Maandishi"

#: prefs.js:301
msgid "Automatically translate extracted text to your target language."
msgstr "Tafsiri maandishi yaliyotolewa kiotomatiki hadi kwa lugha unayolenga."

#: prefs.js:315
msgid "Target Language Code"
msgstr "Msimbo wa Lugha Lengwa"

#: prefs.js:316
msgid "e.g., en, fr, es, zh. Leave empty to use your system default language."
msgstr ""
"k.m., en, fr, es, zh. Acha tupu ili kutumia lugha chaguomsingi ya mfumo wako."

#: prefs.js:333
msgid "Logging"
msgstr "Kuweka magogo"

#: prefs.js:337
msgid "Enable Debug Logging"
msgstr "Washa Kuingia kwa Utatuzi"

#: prefs.js:338
msgid "Outputs detailed OCR and process logs to the system journal."
msgstr ""
"Inatoa maelezo ya kina ya OCR na kumbukumbu za mchakato kwa jarida la mfumo."

