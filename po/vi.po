#: prefs.js:337
msgid "Enable Debug Logging"
msgstr "Bật ghi nhật ký gỡ lỗi"

#: prefs.js:338
msgid "Outputs detailed OCR and process logs to the system journal."
msgstr "Xuất OCR chi tiết và nhật ký quy trình vào nhật ký hệ thống."

