#: prefs.js:59
msgid "Show Extracted Text Notification"
msgstr "Prikaži obavještenje o izdvojenom tekstu"

#: prefs.js:60
msgid "Displays a system banner containing your copied text context."
msgstr "Prikazuje sistemski baner koji sadrži kontekst vašeg kopiranog teksta."

#: prefs.js:74
msgid "Enable Extraction History"
msgstr "Omogući istoriju ekstrakcije"

#: prefs.js:75
msgid "Keep a history of up to 15 recent extractions in the context menu."
msgstr "Sačuvajte istoriju do 15 nedavnih ekstrakcija u kontekstnom meniju."

